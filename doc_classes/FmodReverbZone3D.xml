<?xml version="1.0" encoding="UTF-8" ?>
<class name="FmodReverbZone3D" inherits="Node3D" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/godotengine/godot/master/doc/class.xsd">
	<brief_description>
		Scene node wrapper for an FMOD 3D reverb zone.
	</brief_description>
	<description>
		FmodReverbZone3D creates and owns an internal [FmodReverb3D] object while it is inside the scene tree. The node position is used as the center of the spherical reverb zone. [member min_distance] receives the full reverb effect, and the effect fades out until [member max_distance].
	</description>
	<tutorials>
	</tutorials>
	<methods>
		<method name="get_reverb" qualifiers="const">
			<return type="FmodReverb3D" />
			<description>
				Returns the internal low-level [FmodReverb3D] object, or [code]null[/code] if it has not been created.
			</description>
		</method>
	</methods>
	<members>
		<member name="active" type="bool" setter="set_active" getter="get_active" default="true">
			Whether this reverb zone contributes to the FMOD mix.
		</member>
		<member name="sync_transform" type="bool" setter="set_sync_transform" getter="get_sync_transform" default="true">
			If enabled, the internal FMOD reverb position follows this node every frame.
		</member>
		<member name="min_distance" type="float" setter="set_min_distance" getter="get_min_distance" default="5.0">
			Distance from the center where the reverb is fully applied.
		</member>
		<member name="max_distance" type="float" setter="set_max_distance" getter="get_max_distance" default="20.0">
			Distance from the center where the reverb fades out.
		</member>
		<member name="preset" type="int" setter="set_preset" getter="get_preset" enum="FmodReverbZone3D.Preset" default="2">
			FMOD reverb preset used by the zone. Editing an individual reverb property switches this to [constant PRESET_CUSTOM].
		</member>
		<member name="decay_time" type="float" setter="set_decay_time" getter="get_decay_time" default="1500.0">
			Reverb decay time in milliseconds.
		</member>
		<member name="early_delay" type="float" setter="set_early_delay" getter="get_early_delay" default="7.0">
			Initial reflection delay in milliseconds.
		</member>
		<member name="late_delay" type="float" setter="set_late_delay" getter="get_late_delay" default="11.0">
			Late reverb delay in milliseconds.
		</member>
		<member name="hf_reference" type="float" setter="set_hf_reference" getter="get_hf_reference" default="5000.0">
			High frequency reference in Hz.
		</member>
		<member name="hf_decay_ratio" type="float" setter="set_hf_decay_ratio" getter="get_hf_decay_ratio" default="83.0">
			High-frequency decay ratio in percent.
		</member>
		<member name="diffusion" type="float" setter="set_diffusion" getter="get_diffusion" default="100.0">
			Late reverb diffusion in percent.
		</member>
		<member name="density" type="float" setter="set_density" getter="get_density" default="100.0">
			Late reverb density in percent.
		</member>
		<member name="low_shelf_frequency" type="float" setter="set_low_shelf_frequency" getter="get_low_shelf_frequency" default="250.0">
			Low shelf reference frequency in Hz.
		</member>
		<member name="low_shelf_gain" type="float" setter="set_low_shelf_gain" getter="get_low_shelf_gain" default="0.0">
			Low shelf gain in dB.
		</member>
		<member name="high_cut" type="float" setter="set_high_cut" getter="get_high_cut" default="14500.0">
			High cut frequency in Hz.
		</member>
		<member name="early_late_mix" type="float" setter="set_early_late_mix" getter="get_early_late_mix" default="96.0">
			Early/late reflection mix in percent.
		</member>
		<member name="wet_level" type="float" setter="set_wet_level" getter="get_wet_level" default="-8.0">
			Overall wet level in dB.
		</member>
	</members>
	<constants>
		<constant name="PRESET_CUSTOM" value="0" enum="Preset">
			Custom user-edited reverb properties.
		</constant>
		<constant name="PRESET_OFF" value="1" enum="Preset">
			Disables the reverb effect.
		</constant>
		<constant name="PRESET_GENERIC" value="2" enum="Preset">
			General purpose room reverb.
		</constant>
		<constant name="PRESET_PADDED_CELL" value="3" enum="Preset">
			Very small, heavily damped room.
		</constant>
		<constant name="PRESET_ROOM" value="4" enum="Preset">
			Small room preset.
		</constant>
		<constant name="PRESET_BATHROOM" value="5" enum="Preset">
			Bright reflective bathroom preset.
		</constant>
		<constant name="PRESET_LIVING_ROOM" value="6" enum="Preset">
			Soft furnished room preset.
		</constant>
		<constant name="PRESET_STONE_ROOM" value="7" enum="Preset">
			Reflective stone room preset.
		</constant>
		<constant name="PRESET_AUDITORIUM" value="8" enum="Preset">
			Large auditorium preset.
		</constant>
		<constant name="PRESET_CONCERT_HALL" value="9" enum="Preset">
			Concert hall preset with a long spacious tail.
		</constant>
		<constant name="PRESET_CAVE" value="10" enum="Preset">
			Cave-like reverb with strong late reflections.
		</constant>
		<constant name="PRESET_ARENA" value="11" enum="Preset">
			Very large arena preset.
		</constant>
		<constant name="PRESET_HANGAR" value="12" enum="Preset">
			Huge metallic hangar preset.
		</constant>
		<constant name="PRESET_HALLWAY" value="13" enum="Preset">
			Narrow hallway preset.
		</constant>
		<constant name="PRESET_STONE_CORRIDOR" value="14" enum="Preset">
			Reflective stone corridor preset.
		</constant>
		<constant name="PRESET_ALLEY" value="15" enum="Preset">
			Outdoor alley preset.
		</constant>
		<constant name="PRESET_FOREST" value="16" enum="Preset">
			Outdoor forest ambience preset.
		</constant>
		<constant name="PRESET_CITY" value="17" enum="Preset">
			Outdoor city ambience preset.
		</constant>
		<constant name="PRESET_MOUNTAINS" value="18" enum="Preset">
			Open mountain ambience preset.
		</constant>
		<constant name="PRESET_UNDERWATER" value="19" enum="Preset">
			Underwater muffled reverb preset.
		</constant>
	</constants>
</class>
